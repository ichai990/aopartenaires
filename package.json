{
  "name": "btpilot",
  "version": "0.1.0",
  "private": true,
  "description": "BTPilot — Plateforme SaaS de réponse aux appels d'offres publics pour les entreprises du BTP",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && node scripts/migrate-on-deploy.mjs && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "db:start": "tsx scripts/db.ts start",
    "db:stop": "tsx scripts/db.ts stop",
    "db:status": "tsx scripts/db.ts status",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:setup": "tsx scripts/db.ts start && prisma migrate deploy && prisma db seed",
    "db:reset": "tsx scripts/reset.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "6.19.3",
    "adm-zip": "^0.5.18",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "embedded-postgres": "17.10.0-beta.17",
    "prisma": "6.19.3",
    "tailwindcss": "4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
