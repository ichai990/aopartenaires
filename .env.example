# Base de données (PostgreSQL embarqué en local — remplacer par l'URL Supabase self-hosted en production)
DATABASE_URL="postgresql://btpilot:btpilot@localhost:5433/btpilot"

# Auth.js
AUTH_SECRET="CHANGEZ_MOI_openssl_rand_base64_32"
AUTH_TRUST_HOST=true

# IA — "mock" par défaut ; passer à "anthropic" ou "openai" avec la clé correspondante
AI_PROVIDER="mock"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Email (optionnel — si vide, les liens d'invitation/reset s'affichent dans l'interface)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="BTPilot <no-reply@btpilot.fr>"

# URL publique de l'app (liens d'invitation/reset)
APP_URL="http://localhost:3000"

# Flux des leads du site AO Partenaires (Google Sheet via Apps Script)
LEADS_FEED_URL=""
LEADS_FEED_TOKEN=""

# Stockage des fichiers : "local" (disque, défaut) ou "supabase" (obligatoire sur Vercel)
STORAGE_PROVIDER=""
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="btpilot"
